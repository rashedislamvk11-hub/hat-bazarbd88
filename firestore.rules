rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global safety net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helper Primitives
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isEmailVerified() {
      // Mandated email verification check
      return request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }

    function isAdmin() { 
      // Bootstrap the developer user email as permanent admin
      return isSignedIn() && (
        request.auth.token.email == 'rashedislamvk11@gmail.com' ||
        request.auth.token.email == 'admin@hatbazar.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { 
      return request.resource.data; 
    }

    function existing() { 
      return resource.data; 
    }

    // 3. User profiles validation helper
    function isValidUserProfile(data) {
      return data.uid is string &&
             data.email is string && data.email.size() <= 150 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['admin', 'user'];
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                       isValidUserProfile(incoming()) && 
                       incoming().role == 'user'; // Prevent self-assigning admin role
                       
      allow update: if (isOwner(userId) || isAdmin()) && 
                       isValidUserProfile(incoming()) && 
                       (
                         // Action: modify details (cannot upgrade own role to admin)
                         (!isAdmin() && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])) ||
                         isAdmin()
                       );
      allow delete: if isAdmin();
    }

    // 4. Products collection rules
    function isValidProduct(data) {
      return data.id is string && isValidId(data.id) &&
             data.name is string && data.name.size() <= 200 &&
             data.description is string && data.description.size() <= 1500 &&
             data.price is number && data.price >= 0 &&
             data.category in ['themes', 'plugins', 'ebooks', 'courses', 'software'] &&
             data.imageUrl is string && data.imageUrl.size() <= 500 &&
             data.downloadUrl is string && data.downloadUrl.size() <= 500 &&
             data.fileSize is string && data.fileSize.size() <= 50 &&
             data.version is string && data.version.size() <= 30;
    }

    match /products/{productId} {
      // Anyone can read digital catalog
      allow get, list: if true;
      
      allow create: if isAdmin() && isValidProduct(incoming()) && incoming().id == productId;
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // 5. Orders/Transactions rules
    function isValidOrder(data) {
      return data.id is string &&
             data.userId is string &&
             data.userName is string && data.userName.size() <= 100 &&
             data.userEmail is string && data.userEmail.size() <= 150 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.paymentMethod in ['bkash', 'nagad', 'rocket', 'card'] &&
             data.paymentNumber is string && data.paymentNumber.size() <= 15 &&
             data.transactionId is string && data.transactionId.size() <= 30 &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    match /orders/{orderId} {
      // Customers can only see their own receipts, Admin can see all orders
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                       isValidOrder(incoming()) && 
                       incoming().userId == request.auth.uid && 
                       incoming().status == 'pending' && // Orders must start as pending
                       incoming().id == orderId;
                       
      allow update: if (
        isAdmin() && 
        isValidOrder(incoming()) && (
          // Action: Approve or Reject transaction status
          incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
          // Prevent editing terminal states (Approved is locked)
          existing().status == 'pending'
        )
      );
      allow delete: if isAdmin();
    }
  }
}
